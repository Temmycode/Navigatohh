// Secrets.example.xcconfig
//
// Template for the app's secret configuration values.
//
// SETUP:
//   1. Copy this file to `Secrets.xcconfig` in the same folder (Config/).
//   2. Replace the placeholder below with your real Mapbox PUBLIC access token (starts with "pk.").
//   3. `Secrets.xcconfig` is gitignored — never commit your real token.
//
// The Mapbox SECRET token (Downloads:Read scope, starts with "sk.") is NOT stored here.
// It goes in your `~/.netrc` so Swift Package Manager can download the SDK:
//
//   machine api.mapbox.com
//     login mapbox
//     password sk.YOUR_SECRET_DOWNLOAD_TOKEN

MAPBOX_PUBLIC_TOKEN = pk.REPLACE_WITH_YOUR_PUBLIC_TOKEN
